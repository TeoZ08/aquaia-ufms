# Chave opcional. Sem ela, o AquaIA usa o fallback por regras do MVP.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Dados demo aparecem por padrão. Use false para iniciar sem exemplos.
AQUAIA_SEED_DEMO=true

# O reset demo fica desativado por padrão para não apagar dados acidentalmente.
AQUAIA_ENABLE_RESET=false

# Tarifa estimada para converter desperdício em custo no MVP.
TARIFA_M3_ESTIMADA=71.03

# Ajustes do mapa da Cidade Universitária UFMS.
UFMS_MAP_LAT=-20.5032738
UFMS_MAP_LNG=-54.6134936
UFMS_MAP_ZOOM=16

# Use true apenas em desenvolvimento local.
FLASK_DEBUG=false
