# Copie este arquivo para .env no ambiente local.
# No Render, configure estas variáveis em Environment.
GEMINI_API_KEY=sua_chave_aqui
GEMINI_MODEL=gemini-2.5-flash
AQUAIA_SEED_DEMO=true

# Mapa real sem cadastro: OpenStreetMap + Leaflet.
# Não precisa de chave de API.
# Estes campos apenas controlam o centro inicial do mapa.
UFMS_MAP_LAT=-20.5032738
UFMS_MAP_LNG=-54.6134936
UFMS_MAP_ZOOM=16
